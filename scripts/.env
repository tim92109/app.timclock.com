# TimeClock API Environment Configuration
# Development configuration for local development

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=timeclock_db
DB_USER=timeclock_user
DB_PASSWORD=yGQLC/f8tgUB3M2@L
DB_CONNECTION_LIMIT=10

# JWT Configuration
JWT_SECRET=8f2a9c4e6b1d7f3a5e8c9b2d4f6a8c1e3b5d7f9a2c4e6b8d1f3a5c7e9b2d4f6a8c1e3b5d7f9a2c4e6b8d1f3a5c7e9b
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS Configuration - Allow local frontend
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,https://app.timclock.com
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=3d7b9f2e5a8c1d4f6b9e2a5c8f1b4d7e0a3c6f9b2e5d8a1c4f7b0e3d6a9c2f5e8b1d4a7c0f3e6b9d2a5c8f1b4e7a0
SESSION_TIMEOUT=86400000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Invoice Configuration
INVOICE_PREFIX=INV
INVOICE_NUMBER_LENGTH=6
DEFAULT_CURRENCY=USD
DEFAULT_TAX_RATE=0.00

# Time Tracking Configuration
AUTO_LOGOUT_MINUTES=480
MINIMUM_TIME_ENTRY_MINUTES=1
MAXIMUM_TIME_ENTRY_HOURS=24
