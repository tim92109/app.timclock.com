{
  "name": "timeclock-api",
  "version": "1.0.0",
  "description": "TimeClock Application Backend API Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "setup-db": "powershell -Command \"cd ../../../../assets/DB; ./setup-database.bat\"",
    "setup-db-unix": "bash -c \"cd ../../../../assets/DB && chmod +x setup-database.sh && ./setup-database.sh\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop timeclock-api",
    "pm2:restart": "pm2 restart timeclock-api",
    "pm2:logs": "pm2 logs timeclock-api"
  },
  "keywords": [
    "timeclock",
    "time-tracking",
    "project-management",
    "api",
    "nodejs",
    "express"
  ],
  "author": "TimeClock Development Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "moment": "^2.29.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}